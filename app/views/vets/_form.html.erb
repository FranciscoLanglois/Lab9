<%= render 'shared/error_messages', model: @vet %>

<%= form_with(model: @vet, local: true) do |f| %>
  <div class="mb-3">
    <%= f.label :first_name, class: 'form-label' %>
    <%= f.text_field :first_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :last_name, class: 'form-label' %>
    <%= f.text_field :last_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :email, class: 'form-label' %>
    <%= f.email_field :email, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :phone, class: 'form-label' %>
    <%= f.telephone_field :phone, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :specialization, class: 'form-label' %>
    <%= f.text_field :specialization, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', vets_path, class: 'btn btn-secondary' %>
  </div>
<% end %>