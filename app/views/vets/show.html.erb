<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <h2 class="mb-0">Vet Details</h2>
      <div>
        <% if policy(@vet).update? %>
          <%= link_to "Edit", edit_vet_path(@vet), class: "btn btn-sm btn-warning" %>
        <% end %>
        
        <% if policy(@vet).destroy? %>
          <%= button_to "Delete", vet_path(@vet), 
                        method: :delete, 
                        data: { turbo_confirm: "Are you sure?" }, 
                        class: "btn btn-sm btn-danger" %>
        <% end %>
      </div>
    </div>
    
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <p><strong>First Name:</strong> <%= @vet.first_name %></p>
          <p><strong>Last Name:</strong> <%= @vet.last_name %></p>
        </div>
        <div class="col-md-6">
          <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
          <p><strong>Email:</strong> <%= @vet.email %></p>
          <p><strong>Phone:</strong> <%= @vet.phone %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card mt-4">
    <div class="card-header bg-secondary text-white">
      <h3 class="h5 mb-0">Appointments for Dr. <%= @vet.first_name %> <%= @vet.last_name %></h3>
    </div>
    <div class="card-body">
      <% if @appointments.any? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover table-bordered text-center">
            <thead class="table-dark">
              <tr>
                <th>Pet</th>
                <th>Date</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @appointments.each do |appointment| %>
                <tr>
                  <td><%= link_to appointment.pet&.name, pet_path(appointment.pet), class: "text-decoration-none" if appointment.pet %></td>
                  <td><%= appointment.date.strftime("%B %d, %Y at %I:%M %p") if appointment.date %></td>
                  <td><%= appointment.reason %></td>
                  <td>
                    <span class="badge bg-<%= status_badge_color(appointment.status) %>">
                      <%= appointment.status.titleize %>
                    </span>
                  </td>
                  <td>
                    <%= link_to "View", appointment_path(appointment), class: "btn btn-sm btn-info" %>
                    
                    <% if policy(appointment).update? %>
                      <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-warning" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted text-center mb-0">No appointments scheduled for this vet.</p>
      <% end %>
    </div>
  </div>
  
  <div class="mt-4 d-flex gap-2">
    <%= link_to "Back to Vets", vets_path, class: "btn btn-secondary" %>
    
    <% if policy(Appointment).create? %>
      <%= link_to "New Appointment", new_appointment_path(vet_id: @vet.id), class: "btn btn-primary" %>
    <% end %>
  </div>
</div>