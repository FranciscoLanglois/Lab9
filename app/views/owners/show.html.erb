<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <h2 class="mb-0">
        <% if current_user.owner? && @owner.user == current_user %>
          My Account
        <% else %>
          Owner Details
        <% end %>
      </h2>
      
      <div>
        <% if policy(@owner).update? %>
          <%= link_to "Edit", edit_owner_path(@owner), class: "btn btn-sm btn-warning" %>
        <% end %>
        
        <% if policy(@owner).destroy? %>
          <%= button_to "Delete", owner_path(@owner), 
                        method: :delete, 
                        data: { turbo_confirm: "Are you sure?" }, 
                        class: "btn btn-sm btn-danger" %>
        <% end %>
      </div>
    </div>
    
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-md-6">
          <p><strong>First Name:</strong> <%= @owner.first_name %></p>
          <p><strong>Last Name:</strong> <%= @owner.last_name %></p>
          <p><strong>Email:</strong> <%= @owner.email %></p>
        </div>
        <div class="col-md-6">
          <p><strong>Phone:</strong> <%= @owner.phone %></p>
          <p><strong>Address:</strong> <%= @owner.address %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card mt-4">
    <div class="card-header bg-secondary text-white">
      <h3 class="h5 mb-0">Pets owned by <%= @owner.first_name %> <%= @owner.last_name %></h3>
    </div>
    <div class="card-body">
      <% if @pets.any? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover table-bordered text-center">
            <thead class="table-dark">
              <tr>
                <th>Name</th>
                <th>Species</th>
                <th>Breed</th>
                <th>Date of Birth</th>
                <th>Weight (kg)</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @pets.each do |pet| %>
                <tr>
                  <td><%= link_to pet.name, pet_path(pet), class: "text-decoration-none" %></td>
                  <td><%= pet.species %></td>
                  <td><%= pet.breed %></td>
                  <td><%= pet.date_of_birth.strftime("%B %d, %Y") if pet.date_of_birth %></td>
                  <td><%= pet.weight %></td>
                  <td>
                    <div class="btn-group" role="group">
                      <%= link_to "Show", pet_path(pet), class: "btn btn-sm btn-info" %>
                      
                      <% if policy(pet).update? %>
                        <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-warning" %>
                      <% end %>
                      
                      <% if policy(pet).destroy? %>
                        <%= button_to "Delete", pet_path(pet), 
                                      method: :delete, 
                                      data: { turbo_confirm: "Are you sure?" }, 
                                      class: "btn btn-sm btn-danger" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted text-center mb-0">No pets registered for this owner.</p>
      <% end %>
    </div>
  </div>
  
  <div class="mt-4">
    <% if current_user.owner? && @owner.user == current_user %>
      <%= link_to "Back to Home", root_path, class: "btn btn-secondary" %>
    <% else %>
      <%= link_to "Back to Owners", owners_path, class: "btn btn-secondary" %>
    <% end %>
  </div>
</div>