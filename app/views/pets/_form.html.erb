<%= render 'shared/error_messages', model: @pet %>

<%= form_with(model: @pet, local: true) do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: 'form-label' %>
    <%= f.text_field :name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :species, class: 'form-label' %>
    <%= f.text_field :species, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :breed, class: 'form-label' %>
    <%= f.text_field :breed, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :date_of_birth, class: 'form-label' %>
    <%= f.date_field :date_of_birth, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :weight, class: 'form-label' %>
    <%= f.number_field :weight, step: 0.1, class: 'form-control' %>
  </div>

  <% if current_user.admin? %>
    <div class="mb-3">
      <%= f.label :owner_id, class: 'form-label' %>
      <%= f.collection_select :owner_id, Owner.all, :id, :first_name, 
                            { prompt: 'Select owner' }, 
                            { class: 'form-select' } %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :photo, class: 'form-label' %>
    <% if @pet.photo.attached? %>
      <div class="mb-2">
        <%= image_tag @pet.photo.variant(resize_to_limit: [100, 100]), class: 'img-thumbnail' %>
      </div>
    <% end %>
    <%= f.file_field :photo, class: 'form-control', accept: 'image/jpeg,image/png,image/webp' %>
    <div class="form-text text-muted">Optional. Max 5MB. JPEG, PNG, or WEBP.</div>
  </div>

  <div class="mb-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', pets_path, class: 'btn btn-secondary' %>
  </div>
<% end %>