%= render 'shared/error_messages', model: @treatment %>

<%= form_with(model: [@appointment, @treatment], local: true) do |f| %>
  
  <% if current_user.owner? %>
    <div class="alert alert-warning">
      You are not authorized to create or edit treatments.
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: 'form-label' %>
    <%= f.text_field :name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :medication, class: 'form-label' %>
    <%= f.text_field :medication, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :dosage, class: 'form-label' %>
    <%= f.text_field :dosage, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :administered_at, class: 'form-label' %>
    <%= f.datetime_field :administered_at, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :notes, class: 'form-label' %>
    <%= f.rich_textarea :notes %>
    <div class="form-text text-muted">
      You can use formatted text: <strong>bold</strong>, <em>italics</em>, lists.
    </div>
  </div>

  <div class="mb-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', appointment_path(@appointment), class: 'btn btn-secondary' %>
  </div>
<% end %>