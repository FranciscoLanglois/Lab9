<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
      <h2 class="mb-0">Appointment Details</h2>
      <div>
        <% if policy(@appointment).update? %>
          <%= link_to "Edit", edit_appointment_path(@appointment), class: "btn btn-sm btn-warning" %>
        <% end %>
        
        <% if policy(@appointment).destroy? %>
          <%= button_to "Delete", appointment_path(@appointment), 
                        method: :delete, 
                        data: { turbo_confirm: "Are you sure?" }, 
                        class: "btn btn-sm btn-danger" %>
        <% end %>
      </div>
    </div>
    
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-md-6">
          <p><strong>Pet:</strong> <%= link_to @appointment.pet&.name, pet_path(@appointment.pet) if @appointment.pet %></p>
          <p><strong>Vet:</strong> <%= link_to @appointment.vet&.first_name, vet_path(@appointment.vet) if @appointment.vet %></p>
        </div>
        <div class="col-md-6">
          <p><strong>Date:</strong> <%= @appointment.date&.strftime("%B %d, %Y at %I:%M %p") if @appointment.date %></p>
          <p><strong>Status:</strong> 
            <span class="badge bg-<%= status_badge_color(@appointment.status) %>">
              <%= @appointment.status&.titleize %>
            </span>
          </p>
        </div>
      </div>
      
      <div class="mb-4">
        <p><strong>Reason:</strong></p>
        <div class="border rounded p-3 bg-light">
          <%= @appointment.reason %>
        </div>
      </div>
    </div>
  </div>

  <div class="card mt-4">
    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
      <h3 class="h5 mb-0">Treatments</h3>
      
      <% if policy(Treatment).create? %>
        <%= link_to "New Treatment", new_appointment_treatment_path(@appointment), class: "btn btn-sm btn-success" %>
      <% end %>
    </div>
    
    <div class="card-body">
      <% if @treatments.any? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
              <tr>
                <th>Name</th>
                <th>Medication</th>
                <th>Dosage</th>
                <th>Notes</th>
                <th>Administered At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @treatments.each do |treatment| %>
                <tr>
                  <td><%= treatment.name %></td>
                  <td><%= treatment.medication %></td>
                  <td><%= treatment.dosage %></td>
                  <td>
                    <div class="clinical-notes-preview">
                      <%= truncate(treatment.notes.to_s, length: 100) %>
                    </div>
                  </td>
                  <td><%= treatment.administered_at&.strftime("%Y-%m-%d %H:%M") if treatment.administered_at %></td>
                  <td>
                    <div class="btn-group" role="group">
                      <%= link_to "Show", appointment_treatment_path(@appointment, treatment), class: "btn btn-sm btn-info" if policy(treatment).show? %>
                      
                      <% if policy(treatment).update? %>
                        <%= link_to "Edit", edit_appointment_treatment_path(@appointment, treatment), class: "btn btn-sm btn-warning" %>
                      <% end %>
                      
                      <% if policy(treatment).destroy? %>
                        <%= button_to "Delete", appointment_treatment_path(@appointment, treatment), 
                                      method: :delete, 
                                      data: { turbo_confirm: "Are you sure?" }, 
                                      class: "btn btn-sm btn-danger" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted text-center mb-0">No treatments for this appointment.</p>
      <% end %>
    </div>
  </div>
  
  <div class="mt-4">
    <%= link_to "Back to Appointments", appointments_path, class: "btn btn-secondary" %>
  </div>
</div>

<% if @treatments.any? %>
  <style>
    .clinical-notes-preview {
      max-width: 300px;
      overflow: hidden;
      white-space: normal;
    }
  </style>
<% end %>