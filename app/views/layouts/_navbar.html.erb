<nav class="navbar bg-primary" data-bs-theme="dark">
  <div class="container">
    <%= link_to "Home", root_path, class: "navbar-brand fw-bold" %>
    
    <div class="d-flex align-items-center">
      <% if user_signed_in? %>
        <% if current_user.admin? || current_user.vet? %>
          <%= link_to "Owners", owners_path, class: "nav-link text-white mx-2" %>
          <%= link_to "Pets", pets_path, class: "nav-link text-white mx-2" %>
          <%= link_to "Vets", vets_path, class: "nav-link text-white mx-2" %>
          <%= link_to "Appointments", appointments_path, class: "nav-link text-white mx-2" %>
        <% elsif current_user.owner? %>
          <%= link_to "My account", owner_path(current_user.owner), class: "nav-link text-white mx-2" %>
          <%= link_to "Pets", pets_path, class: "nav-link text-white mx-2" %>
          <%= link_to "Vets", vets_path, class: "nav-link text-white mx-2" %>
          <%= link_to "Appointments", appointments_path, class: "nav-link text-white mx-2" %>
        <% end %>
        
        <div class="border-start border-light mx-2"></div>
        
        <div class="d-flex align-items-center gap-2">
          <span class="text-white me-2">
            <%= current_user.first_name %> <%= current_user.last_name %>
          </span>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-light" %>
        </div>
      <% else %>
        <%= link_to "Log In", new_user_session_path, class: "nav-link text-white mx-2" %>
      <% end %>
    </div>
  </div>
</nav>